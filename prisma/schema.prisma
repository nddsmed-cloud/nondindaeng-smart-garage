// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ตารางผู้ใช้งานระบบ
model User {
  id         String   @id @default(uuid())
  name       String
  username   String   @unique
  password   String?
  // RBAC Roles: ADMIN_OFFICER | INSPECTOR_ENGINEER | DIRECTOR | EXECUTIVE | DRIVER | ADMIN
  role       String   @default("ADMIN_OFFICER") 
  department String   @default("")
  isActive   Boolean  @default(true) @map("is_active")
  lineUserId String?  @unique @map("line_user_id")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

// ตารางรายการจดทะเบียนรถ (คส.1)
model Vehicle {
  id              String   @id @default(uuid())
  registeredDate  DateTime @map("registered_date")
  licensePlate    String   @map("license_plate")
  province        String
  vehicleType     String   @map("vehicle_type")
  bodyType        String   @map("body_type")
  brand           String
  model           String
  color           String
  chassisNumber   String   @unique @map("chassis_number")
  engineNumber    String   @unique @map("engine_number")
  fuelType        String   @map("fuel_type")
  engineCapacity  Int      @map("engine_capacity")
  emptyWeight     Int      @map("empty_weight")
  payloadWeight   Int      @map("payload_weight")
  totalWeight     Int      @map("total_weight")
  status          String   @default("พร้อมใช้งาน")
  department      String?  @default("")
  standardConsumptionRate Float @default(13.0) @map("standard_consumption_rate")
  assetNumber     String?  @default("") @map("asset_number")
  acquiredPrice   Float?   @default(0) @map("acquired_price")
  
  // รูปภาพและข้อมูลเพิ่มเติม (อัปเดตใหม่)
  imageUrl        String?  @map("image_url")
  notes           String?  @default("")
  gisLink         String?  @default("") @map("gis_link")

  tripLogs        TripLog[]
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
  vehicleRequests VehicleRequest[]
  maintenanceDocs MaintenanceDocument[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("vehicles")
}

// ตารางคำขออนุญาตใช้รถยนต์ส่วนกลาง
model VehicleRequest {
  id            String   @id @default(uuid())
  requesterName String   @map("requester_name")
  department    String
  purpose       String
  vehicleType   String   @map("vehicle_type")
  travelDate    String   @map("travel_date")
  destination   String   @default("")
  status        String   @default("รออนุมัติ")
  note          String   @default("")

  // การเชื่อมโยงรถยนต์และเลขไมล์เริ่มต้น
  vehicleId     String?  @map("vehicle_id")
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  startMileage  Int?     @map("start_mileage")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("vehicle_requests")
}

// ตารางบันทึกการเดินทาง
model TripLog {
  id            String   @id @default(uuid())
  vehicleId     String   @map("vehicle_id")
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  driverName    String   @map("driver_name")
  department    String
  destination   String
  purpose       String
  travelDate    String   @map("travel_date")
  startMileage  Int      @map("start_mileage")
  endMileage    Int      @default(0) @map("end_mileage")
  distance      Int      @default(0)
  status        String   @default("กำลังเดินทาง")
  userId        String?  @map("user_id")

  // เพิ่มการเชื่อมโยงกับถนน (GIS)
  roadId        String?  @map("road_id")
  road          InfraAsset? @relation(fields: [roadId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("trip_logs")
}

// ตารางบันทึกการเติมน้ำมัน
model FuelLog {
  id            String   @id @default(uuid())
  vehicleId     String   @map("vehicle_id")
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  fuelDate      String   @map("fuel_date")
  liters        Float
  pricePerLiter Float    @map("price_per_liter")
  totalCost     Float    @map("total_cost")
  
  // ข้อมูลไมล์และอัตราสิ้นเปลือง (สตง.)
  startMileage  Int      @default(0) @map("start_mileage")
  endMileage    Int      @map("end_mileage")
  distance      Int      @default(0)
  standardRate  Float    @default(13.0) @map("standard_rate")
  expectedFuel  Float    @default(0) @map("expected_fuel")
  fuelDifference Float   @default(0) @map("fuel_difference")
  explanation   String   @default("")

  fuelStation   String   @default("") @map("fuel_station")
  note          String   @default("")
  userId        String?  @map("user_id")
  department    String?  @default("")
  status        String   @default("รออนุมัติ")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("fuel_logs")
}

// ตารางแบบ ๖ รายละเอียดการซ่อมบำรุง
model MaintenanceLog {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  maintenanceDate String   @map("maintenance_date")
  mileage         Int
  details         String
  cost            Float
  garageName      String   @map("garage_name")
  responsibleName String   @map("responsible_name")
  department      String   @default("")
  userId          String?  @map("user_id")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("maintenance_logs")
}

// ตารางบันทึกการออกเอกสารซ่อมบำรุง (ว 2600)
model MaintenanceDocument {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  
  documentDate    DateTime @default(now()) @map("document_date")
  mileage         Int
  symptoms        String   // อาการที่พบ
  partsReplaced   String   @map("parts_replaced") // อะไหล่ที่ต้องเปลี่ยน
  estimatedCost   Float    @map("estimated_cost") // ประมาณการค่าใช้จ่าย
  garageName      String   @map("garage_name") // ชื่ออู่ซ่อม
  garageReason    String   @map("garage_reason") // เหตุผลที่เลือกอู่นี้
  
  // คณะกรรมการ
  committee1      String   // ประธาน
  committee2      String   // กรรมการ
  committee3      String   // กรรมการ
  
  inspectorName   String   @map("inspector_name") // ผู้ตรวจสอบสภาพรถ (ช่าง)
  reporterName    String   @map("reporter_name") // ผู้แจ้งซ่อม (พนักงานขับรถ)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("maintenance_documents")
}

// ตารางจัดการสิทธิ์ LINE กลุ่ม (LIFF)
model GroupAccess {
  id             String   @id @default(uuid())
  lineGroupId    String   @unique @map("line_group_id")
  departmentName String   @map("department_name")
  defaultRole    String   @default("DRIVER") @map("default_role")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("group_access")
}

// ─────────────────────────────────────────────────────────────
// GIS กองช่าง — โมดูลทะเบียนถนนและสิ่งติดตั้ง
// ─────────────────────────────────────────────────────────────

enum FixtureType {
  STREETLIGHT   // เสาไฟฟ้าแสงสว่าง
  TRAFFIC_SIGN  // ป้ายจราจร
  CCTV          // กล้องวงจรปิด
  OTHER         // อื่นๆ
}

enum FixtureStatus {
  NORMAL        // ปกติ
  UNDER_REPAIR  // อยู่ระหว่างซ่อม
  DAMAGED       // ชำรุด
}

enum SurfaceType {
  ASPHALT   // ลาดยาง
  CONCRETE  // คอนกรีต (ค.ส.ล.)
  LATERITE  // ลูกรัง
  GRAVEL    // หินคลุก
  EARTH     // ดิน
}

enum LandDocType {
  TITLE_DEED          // มีเอกสารสิทธิ์ที่ดิน (โฉนด/น.ส.3)
  TT4_DEDICATION      // หนังสืออุทิศที่ดิน (ทถ.4)
  TT5_CERTIFICATION   // หนังสือรับรองที่ดินสาธารณประโยชน์ (ทถ.5)
}

// ถนนแต่ละสาย
model InfraAsset {
  id           String            @id @default(cuid())
  name         String
  path         Json              @default("[]") // array ของ {lat, lng}
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  registration RoadRegistration?
  fixtures     RoadFixture[]
  tripLogs     TripLog[]

  @@map("infra_assets")
}

// ทถ.3 — รายละเอียดเชิงกายภาพของถนน
model RoadRegistration {
  id               String       @id @default(cuid())
  assetId          String       @unique @map("asset_id")
  asset            InfraAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  routeCode        String?      @map("route_code")
  lengthKm         Float?       @map("length_km")
  surfaceType      SurfaceType? @map("surface_type")
  pavementWidth    Float?       @map("pavement_width")
  rightOfWayWidth  Float?       @map("right_of_way_width")
  shoulderWidth    Float?       @map("shoulder_width")
  sidewalkWidth    Float?       @map("sidewalk_width")
  drainageDetail   String?      @map("drainage_detail")
  landDocumentType LandDocType? @map("land_document_type")
  status           String       @default("APPROVED")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("road_registrations")
}

// สิ่งติดตั้งบนถนน (เสาไฟ / ป้ายจราจร / กล้อง CCTV)
model RoadFixture {
  id        String        @id @default(cuid())
  assetId   String        @map("asset_id")
  asset     InfraAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type      FixtureType
  detail    String?       // เช่น "LED 40W", "ป้ายหยุด"
  lat       Float
  lng       Float
  status    FixtureStatus @default(NORMAL)
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("road_fixtures")
}

// Vehicle Maintenance module
model MaintenanceVehicle {
  id            Int       @id @default(autoincrement())
  plateNumber   String    @unique
  vehicleType   String
  brand         String
  model         String
  yearAcquired  Int
  status        VehicleStatus @default(ACTIVE)
  insuranceExp  DateTime?
  taxExp        DateTime?
  maintenances  MaintenanceRecord[]
  createdAt     DateTime @default(now())
}

model MaintenanceRecord {
  id              Int       @id @default(autoincrement())
  vehicleId       Int
  vehicle         MaintenanceVehicle   @relation(fields: [vehicleId], references: [id])
  reportedById    Int
  symptom         String
  status          MaintenanceStatus @default(REPORTED)
  cost            Decimal?  @db.Decimal(10,2)
  serviceProvider String?
  comparison      ComparisonScore?
  documentUrl     String?
  approvedById    Int?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  completedAt     DateTime?
}

model ComparisonScore {
  id                Int      @id @default(autoincrement())
  maintenanceId     Int      @unique
  maintenance       MaintenanceRecord @relation(fields: [maintenanceId], references: [id])
  workTypeScore     Int
  vehicleAgeScore   Int
  partsQualityScore Int
  warrantyScore     Int
  safetyScore       Int
  recommendedOption String
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum MaintenanceStatus {
  REPORTED
  COMPARISON_DONE
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ─────────────────────────────────────────────────────────────
// ระบบสารบรรณ — ทะเบียนหนังสือรับ / หนังสือส่ง
// ─────────────────────────────────────────────────────────────

enum DocDirection {
  IN    // หนังสือรับ
  OUT   // หนังสือส่ง
}

enum DocUrgency {
  NORMAL  // ปกติ
  URGENT  // ด่วน
  VERY_URGENT // ด่วนมาก
}

model Saraban {
  id            String        @id @default(cuid())

  // เลขที่หนังสือ
  docNumber     String        @unique @map("doc_number")  // เช่น กช.0001/2568
  docDate       String        @map("doc_date")            // วันที่หนังสือ (พ.ศ.)
  direction     DocDirection                               // IN / OUT

  // รายละเอียด
  subject       String                                     // เรื่อง
  fromOrg       String        @map("from_org")            // จาก (หน่วยงานต้นทาง)
  toOrg         String        @default("") @map("to_org") // ถึง (หน่วยงานปลายทาง)
  urgency       DocUrgency    @default(NORMAL)
  detail        String        @default("")                 // รายละเอียดเพิ่มเติม

  // การดำเนินการ
  status        String        @default("pending")         // pending | inprogress | completed
  assignedTo    String        @default("") @map("assigned_to") // ชื่อผู้รับผิดชอบ
  dueDate       String?       @map("due_date")
  completedNote String        @default("") @map("completed_note")

  // เอกสารแนบ
  attachmentUrl String?       @map("attachment_url")

  // บันทึกโดย
  createdBy     String        @default("") @map("created_by")

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("saraban")
}

// ─────────────────────────────────────────────────────────────
// ระบบ e-Permit — ขออนุญาตก่อสร้างออนไลน์
// ─────────────────────────────────────────────────────────────

enum PermitStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model BuildingPermit {
  id              String        @id @default(cuid())
  permitNumber    String?       @unique @map("permit_number")
  
  // ผู้ยื่นขอ
  applicantName   String        @map("applicant_name")
  applicantPhone  String        @map("applicant_phone")
  applicantLineId String?       @map("applicant_line_id")
  
  // รายละเอียดการขอ
  buildingType    String        @map("building_type") // อ.1, อ.6, ขุดดิน ฯลฯ
  address         String
  lat             Float?
  lng             Float?
  documentUrl     String?       @map("document_url") // URL ไฟล์แนบ PDF/AutoCAD
  
  status          PermitStatus  @default(PENDING)
  officerComment  String?       @map("officer_comment") // หมายเหตุจากเจ้าหน้าที่
  
  approvedById    String?       @map("approved_by_id") // ID เจ้าหน้าที่ที่อนุมัติ
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("building_permits")
}

// ─────────────────────────────────────────────────────────────
// ระบบ e-Service — รับแจ้งซ่อมและสั่งการช่าง
// ─────────────────────────────────────────────────────────────

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model RepairRequest {
  id              String        @id @default(cuid())
  requestCode     String?       @unique @map("request_code")
  
  // ผู้แจ้ง
  reporterName    String        @map("reporter_name")
  reporterPhone   String        @map("reporter_phone")
  reporterLineId  String?       @map("reporter_line_id")
  
  // รายละเอียดการแจ้งซ่อม
  category        String        // ไฟฟ้า, ถนน, ท่อระบายน้ำ ฯลฯ
  description     String
  location        String
  lat             Float?
  lng             Float?
  geom            Unsupported("geometry(Point, 4326)")?
  imageBeforeUrl  String?       @map("image_before_url")
  
  status          RepairStatus  @default(PENDING)
  
  // การสั่งงาน
  workOrder       WorkOrder?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("repair_requests")
}

model WorkOrder {
  id              String        @id @default(cuid())
  
  repairRequestId String        @unique @map("repair_request_id")
  repairRequest   RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  
  technicianName  String?       @map("technician_name")
  assignedAt      DateTime      @default(now()) @map("assigned_at")
  
  imageAfterUrl   String?       @map("image_after_url")
  geom            Unsupported("geometry(Point, 4326)")?
  note            String?       // บันทึกของช่าง
  completedAt     DateTime?     @map("completed_at")

  @@map("work_orders")
}